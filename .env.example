# привет от пазитива <3

#получить эти данные можно, создав приложение на https://my.telegram.org/apps
API_ID=
API_HASH=
SESSION_NAME=userbot

#получить эти данные можно, создав приложение на https://developer.spotify.com/dashboard/applications
SPOTIPY_CLIENT_ID=
SPOTIPY_CLIENT_SECRET=
SPOTIPY_REDIRECT_URI=http://127.0.0.1:8888/callback
SPOTIPY_REFRESH_TOKEN=    # получить через: python setup_spotify.py

#погода берётся с wttr.in — без ключей
CITY=Yekaterinburg
TIMEZONE=Asia/Yekaterinburg

#интервал обновления биографии в секундах
#осторожно! слишком маленький интервал может привести к блокировке аккаунта за спам
UPDATE_INTERVAL=30
MAX_BIO_LEN=140
BIO_SUFFIX=порт: @portpazik
